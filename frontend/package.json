{
  "name": "book-pagination-frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "pnpm gen:api",
    "dev": "vite",
    "prebuild": "pnpm gen:api",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "pretest:unit": "pnpm gen:api",
    "test:unit": "vitest",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "gen:api": "openapi-ts",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "run-s format:*",
    "format:src": "oxfmt src/",
    "format:md": "cd .. && oxfmt '**/*.md'"
  },
  "dependencies": {
    "@primeuix/themes": "^2.0.3",
    "@vueuse/core": "^14.3.0",
    "@vueuse/router": "^14.3.0",
    "dayjs": "^1.11.20",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.5",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "0.86.12",
    "@tailwindcss/vite": "4.2.4",
    "@tsconfig/node24": "24.0.4",
    "@types/jsdom": "28.0.1",
    "@types/node": "24.12.2",
    "@vitejs/plugin-vue": "6.0.6",
    "@vitest/eslint-plugin": "1.6.16",
    "@vue/eslint-config-typescript": "14.7.0",
    "@vue/test-utils": "2.4.10",
    "@vue/tsconfig": "0.9.1",
    "eslint": "10.3.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-oxlint": "1.62.0",
    "eslint-plugin-vue": "10.9.0",
    "jiti": "2.6.1",
    "jsdom": "29.1.1",
    "npm-run-all2": "8.0.4",
    "oxfmt": "0.46.0",
    "oxlint": "1.62.0",
    "tailwindcss": "4.2.4",
    "tailwindcss-primeui": "0.6.1",
    "typescript": "6.0.3",
    "vite": "8.0.10",
    "vite-plugin-vue-devtools": "8.1.1",
    "vitest": "4.1.5",
    "vue-tsc": "3.2.8"
  },
  "engines": {
    "node": "24.15.0"
  },
  "packageManager": "pnpm@10.33.3"
}
